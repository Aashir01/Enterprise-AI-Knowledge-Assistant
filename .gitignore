faiss_index/
*.faiss
*.pkl

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Uploaded data (user files)
data/uploads/

# Jupyter
.ipynb_checkpoints/
